<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <PDF4LLMLayoutToolsDir Condition="Exists('$(MSBuildThisFileDirectory)layout\setup_layout_python.py')">$(MSBuildThisFileDirectory)layout\</PDF4LLMLayoutToolsDir>
    <PDF4LLMLayoutToolsDir Condition="'$(PDF4LLMLayoutToolsDir)' == '' and Exists('$(MSBuildThisFileDirectory)..\scripts\setup_layout_python.py')">$(MSBuildThisFileDirectory)..\scripts\</PDF4LLMLayoutToolsDir>
  </PropertyGroup>

  <!-- Opt-in: dotnet msbuild -t:PDF4LLMSetupLayoutPython -->
  <Target Name="PDF4LLMSetupLayoutPython">
    <Error Condition="!Exists('$(PDF4LLMLayoutToolsDir)setup_layout_python.py')"
           Text="PDF4LLM layout setup scripts are missing from the NuGet package ($(PDF4LLMLayoutToolsDir))." />
    <Exec Condition="'$(OS)' == 'Windows_NT'"
          Command="powershell -NoProfile -ExecutionPolicy Bypass -File &quot;$(PDF4LLMLayoutToolsDir)setup_layout_python.ps1&quot;" />
    <!-- Invoke Python directly on Unix — avoids CRLF issues in packed .sh from Windows builds. -->
    <Exec Condition="'$(OS)' != 'Windows_NT'"
          Command="python3 &quot;$(PDF4LLMLayoutToolsDir)setup_layout_python.py&quot;" />
  </Target>
</Project>
